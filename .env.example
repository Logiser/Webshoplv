# ============================================
# MunkavédelmiShop - környezeti változók
# ============================================
# 
# A .env fájl NEM kerül a Git-be (lásd .gitignore).
# Production-ben Netlify Environment Variables-t használj!
# Netlify Dashboard → Site settings → Environment variables
# 
# ============================================

# ============ EMAIL KÜLDÉS (Resend) ============
# Regisztrálj resend.com-on (ingyenes 3000 email/hó)
# API kulcs: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Admin email - ide jönnek az értesítések új rendelésről
ADMIN_EMAIL=iroda@tuz-munkavedelmiszaki.hu

# Feladó email
# Alapból (saját domain nélkül): onboarding@resend.dev
# Saját domain után (igazolt domain-nel): noreply@tuz-munkavedelmiszaki.hu
FROM_EMAIL=onboarding@resend.dev

# ============ ANALYTICS ============
# Google Analytics 4
# Setup: analytics.google.com → új property → Mérési ID másolása
REACT_APP_GA4_ID=G-XXXXXXXXXX

# Facebook Pixel
# Setup: business.facebook.com → Events Manager → új Pixel
REACT_APP_FB_PIXEL_ID=1234567890123456

# ============ ADMIN JELSZÓ ============
# Production-ben mindenképp változtasd meg!
REACT_APP_ADMIN_PASSWORD=admin123

# ============ EGYÉB ============
REACT_APP_SHIPPING_COST=1990
REACT_APP_SITE_URL=https://munkavedelmiszaki.hu
